{
  "version": 2,
  "builds": [
    { "src": "api/server.js", "use": "@vercel/node" },
    { "src": "public/**", "use": "@vercel/static" }
  ],
  "routes": [
    { "src": "/api/server.js", "dest": "/public/index.html" },
    { "src": "/api/(.*)", "dest": "api/server.js" },
    { "src": "/go/(.*)", "dest": "api/server.js" },
    { "src": "/", "dest": "/public/index.html" },
    { "src": "/(.*)", "dest": "public/$1" }
  ]
}
